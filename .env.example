# --- Required ---
# Wallet to watch (the one with the standing MIM sell order on CoW Swap)
WALLET_ADDRESS=0xYourWalletAddressHere

# Telegram bot credentials (see README for how to get these)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# --- Optional (sensible defaults) ---
# MIM on Ethereum mainnet
MIM_ADDRESS=0x99D8a9C45b2ecA8864373A26D1459e3Dff1e17F3
# CoW Swap orderbook API (mainnet)
COW_API_BASE=https://api.cow.fi/mainnet/api/v1
# Keyless public RPC(s), used only to resolve buy-token symbol/decimals.
# Comma-separated; tried in order until one answers. Common tokens (USDC, USDT,
# DAI, WETH, MIM) are hardcoded, so this only matters for exotic buy tokens.
ETH_RPC_URL=https://ethereum-rpc.publicnode.com,https://eth.drpc.org
# How often to poll, in seconds
POLL_INTERVAL_SEC=60
# Where to persist the high-water mark. On Railway, mount a Volume and point
# this at it so restarts don't replay or miss fills, e.g. /data/state.json
STATE_FILE=./state.json
# Block explorer tx link prefix
EXPLORER_TX_BASE=https://etherscan.io/tx/
